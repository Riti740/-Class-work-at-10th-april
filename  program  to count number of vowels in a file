      "source": [
        "# to open file for read operation\n",
        "filev = open(\"firstfile.txt\", \"r\")\n",
        "\n",
        "# to check file is open or not\n",
        "if(filev):\n",
        "\n",
        "    # to read data from file\n",
        "    data = filev.read()\n",
        "    print(data)\n",
        "\n",
        "    print(\"----------------------\")\n",
        "\n",
        "    # count vowels\n",
        "    count = 0\n",
        "    for ch in data:\n",
        "        if ch.lower() in ['a', 'e', 'i', 'o', 'u']:\n",
        "            count += 1\n",
        "\n",
        "    print(\"No. of vowels :\", count)\n",
        "\n",
        "    # closing file\n",
        "    filev.close()\n",
        "\n",
        "else:\n",
        "    print(\"Unable to open the file\")"
