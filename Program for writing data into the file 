        "# program for writing data into the file\n",
        "\n",
        "# opening file for write operation\n",
        "filev = open(\"file.txt\", \"w\")\n",
        "\n",
        "# writing twenty sentences into the file\n",
        "print(\"Enter any twenty sentences:\")\n",
        "\n",
        "for x in range(20):\n",
        "    sentence = input()\n",
        "        filev.write(sentence + \"\\n\")   # new line add kiya\n",
        "\n",
        "        print(\"Data successfully written\")\n",
        "\n",
        "        # closing the file\n",
        "        filev.close()"
